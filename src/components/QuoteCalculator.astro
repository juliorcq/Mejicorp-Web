<section id="cotizador" class="py-32 bg-white">
    <div class="max-w-6xl mx-auto px-6">
  
      <!-- Header editorial -->
      <div class="max-w-2xl mb-20">
        <span class="text-sm uppercase tracking-widest text-gray-500">
          Cotización rápida
        </span>
  
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3">
          Calcula tu inversión estimada
        </h2>
  
        <p class="text-lg text-gray-600 mt-6 leading-relaxed">
          Selecciona las características de tu proyecto y obtén un costo aproximado
          al instante. Te ayudará a planificar tu presupuesto antes de contactarme.
        </p>
      </div>
  
      <!-- Card -->
      <div class="grid lg:grid-cols-2 gap-16 items-start">
  
        <!-- Opciones -->
        <div class="space-y-10">
  
          <!-- Tipo -->
          <div>
            <label class="block font-medium text-gray-900 mb-2">
              Tipo de proyecto
            </label>
            <select id="type" class="w-full border rounded-xl px-4 py-3">
              <option value="500">Landing page</option>
              <option value="1000">Sitio corporativo</option>
              <option value="2000">Sistema web</option>
              <option value="3000">E-commerce</option>
            </select>
          </div>
  
          <!-- Extras -->
          <div>
            <p class="font-medium text-gray-900 mb-3">Funcionalidades extra</p>
  
            <div class="space-y-3 text-sm text-gray-700">
  
              <label class="flex items-center gap-2">
                <input type="checkbox" value="300" class="extra">
                SEO avanzado
              </label>
  
              <label class="flex items-center gap-2">
                <input type="checkbox" value="400" class="extra">
                Panel administrador
              </label>
  
              <label class="flex items-center gap-2">
                <input type="checkbox" value="350" class="extra">
                Blog / noticias
              </label>
  
              <label class="flex items-center gap-2">
                <input type="checkbox" value="500" class="extra">
                Pagos online
              </label>
  
            </div>
          </div>
  
          <!-- Complejidad -->
          <div>
            <label class="block font-medium text-gray-900 mb-3">
              Complejidad
            </label>
  
            <input
              id="complexity"
              type="range"
              min="1"
              max="3"
              value="1"
              class="w-full"
            />
  
            <p class="text-sm text-gray-500 mt-2">
              Básico — Medio — Avanzado
            </p>
          </div>
  
        </div>
  
        <!-- Resultado -->
        <div
          class="bg-gray-50 rounded-3xl border p-12 text-center
                 sticky top-32 space-y-6"
        >
          <p class="text-sm uppercase tracking-wide text-gray-500">
            Costo estimado
          </p>
  
          <p id="price" class="text-5xl font-bold text-blue-600">
            S/. 0
          </p>
  
          <p id="time" class="text-gray-600"></p>
  
          <a
            href="/contacto"
            class="inline-block bg-blue-600 text-white px-8 py-3 rounded-full
                   hover:bg-blue-700 transition"
          >
            Solicitar cotización real
          </a>
        </div>
  
      </div>
    </div>
  
    <!-- JS -->
    <script is:inline>
      const type = document.getElementById("type");
      const extras = document.querySelectorAll(".extra");
      const complexity = document.getElementById("complexity");
      const price = document.getElementById("price");
      const time = document.getElementById("time");
  
      function calc() {
        let total = Number(type.value);
  
        extras.forEach(e => {
          if (e.checked) total += Number(e.value);
        });
  
        total *= Number(complexity.value);
  
        price.textContent = "S/. " + total.toLocaleString();
  
        const days = 4 * complexity.value + Math.round(total / 600);
        time.textContent = "Tiempo estimado: " + days + " días";
      }
  
      document.querySelectorAll("select, input").forEach(el => {
        el.addEventListener("input", calc);
      });
  
      calc();
    </script>
  </section>
  
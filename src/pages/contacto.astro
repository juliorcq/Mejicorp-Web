---
import MainLayout from "../layouts/MainLayout.astro"
import "../styles/global.css";---

<MainLayout>
  <section class="min-h-screen bg-white py-32">
    <div class="max-w-4xl mx-auto px-6">

      <!-- Header editorial -->
      <div class="max-w-2xl mb-16">
        <span class="text-sm uppercase tracking-widest text-gray-500">
          Contacto
        </span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-4">
          Hablemos sobre tu proyecto
        </h1>
        <p class="text-lg text-gray-600 mt-6 leading-relaxed">
          Si tienes una idea, proyecto o consulta, puedes contactarme
          completando el siguiente formulario.
        </p>
      </div>

      <!-- Formulario -->
      <form class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="space-y-2">
          <label class="text-sm font-medium text-gray-700">
            Nombre
          </label>
          <input
            type="text"
            placeholder="Tu nombre"
            class="w-full border border-gray-300 rounded-xl px-4 py-3
                   focus:outline-none focus:border-blue-600"
          />
        </div>

        <div class="space-y-2">
          <label class="text-sm font-medium text-gray-700">
            Correo electrónico
          </label>
          <input
            type="email"
            placeholder="correo@email.com"
            class="w-full border border-gray-300 rounded-xl px-4 py-3
                   focus:outline-none focus:border-blue-600"
          />
        </div>

        <div class="md:col-span-2 space-y-2">
          <label class="text-sm font-medium text-gray-700">
            Mensaje
          </label>
          <textarea
            rows="5"
            placeholder="Cuéntame sobre tu proyecto..."
            class="w-full border border-gray-300 rounded-xl px-4 py-3
                   focus:outline-none focus:border-blue-600"
          ></textarea>
        </div>

        <div class="md:col-span-2">
          <button
            type="submit"
            class="inline-flex items-center px-8 py-3
                   bg-blue-600 text-white rounded-full
                   hover:bg-blue-700 transition"
          >
            Enviar mensaje
          </button>
        </div>

      </form>

    </div>
  </section>
</MainLayout>

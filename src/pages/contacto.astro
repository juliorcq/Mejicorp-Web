---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";

const title = "Contacto | Mejicorp – Desarrollo web y soluciones digitales";
const description =
  "Contáctate con Mejicorp para cotizar desarrollo web, diseño UX/UI, optimización SEO o soluciones digitales a medida.";
---

<MainLayout title={title} description={description}>
  <section class="relative min-h-screen overflow-hidden bg-white py-32">

    <!-- Fondos decorativos elegantes -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-[-12rem] right-[-12rem]
                  w-[30rem] h-[30rem]
                  bg-blue-100 rounded-full blur-3xl opacity-60"></div>

      <div class="absolute bottom-[-12rem] left-[-12rem]
                  w-[26rem] h-[26rem]
                  bg-indigo-100 rounded-full blur-3xl opacity-60"></div>
    </div>

    <div class="max-w-5xl mx-auto px-6">

      <!-- Header editorial -->
      <header class="max-w-2xl mb-20">
        <span class="inline-block text-sm uppercase tracking-widest text-gray-500">
          Contacto
        </span>

        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-4 leading-tight">
          Hablemos sobre tu
          <span class="text-blue-600 block">proyecto digital</span>
        </h1>

        <p class="text-lg text-gray-600 mt-6 leading-relaxed">
          Cuéntame qué necesitas y te responderé con una propuesta clara,
          realista y alineada a tus objetivos.
        </p>
      </header>

      <!-- Contenedor formulario -->
      <div class="grid lg:grid-cols-3 gap-16 items-start">

        <!-- Info lateral -->
        <aside class="space-y-8">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">
              ¿Qué puedes solicitar?
            </h3>
            <ul class="space-y-2 text-gray-600 text-sm">
              <li>• Desarrollo web corporativo</li>
              <li>• Landing pages optimizadas</li>
              <li>• UX / UI y diseño visual</li>
              <li>• Optimización SEO y performance</li>
              <li>• Asesoría técnica</li>
            </ul>
          </div>

          <div class="p-6 rounded-2xl bg-gray-50 border">
            <p class="text-sm text-gray-600 leading-relaxed">
              Normalmente respondo en menos de
              <strong class="text-gray-900"> 24 horas</strong>.
              Toda la información compartida es confidencial.
            </p>
          </div>
        </aside>

        <!-- Formulario -->
        <form
          class="lg:col-span-2 bg-white rounded-3xl border p-10 shadow-sm space-y-8"
        >

          <!-- Nombre -->
          <div class="space-y-2">
            <label class="text-sm font-medium text-gray-700">
              Nombre completo
            </label>
            <input
              type="text"
              placeholder="Tu nombre"
              required
              class="w-full rounded-xl border border-gray-300 px-4 py-3
                     focus:outline-none focus:border-blue-600"
            />
          </div>

          <!-- Correo -->
          <div class="space-y-2">
            <label class="text-sm font-medium text-gray-700">
              Correo electrónico
            </label>
            <input
              type="email"
              placeholder="correo@empresa.com"
              required
              class="w-full rounded-xl border border-gray-300 px-4 py-3
                     focus:outline-none focus:border-blue-600"
            />
          </div>

          <!-- Empresa -->
          <div class="space-y-2">
            <label class="text-sm font-medium text-gray-700">
              Empresa u organización (opcional)
            </label>
            <input
              type="text"
              placeholder="Nombre de la empresa"
              class="w-full rounded-xl border border-gray-300 px-4 py-3
                     focus:outline-none focus:border-blue-600"
            />
          </div>

          <!-- Servicio -->
          <div class="space-y-2">
            <label class="text-sm font-medium text-gray-700">
              Servicio de interés
            </label>
            <select
              class="w-full rounded-xl border border-gray-300 px-4 py-3
                     focus:outline-none focus:border-blue-600"
            >
              <option>Desarrollo web</option>
              <option>Landing page</option>
              <option>UX / UI</option>
              <option>SEO & Performance</option>
              <option>Asesoría técnica</option>
            </select>
          </div>

          <!-- Presupuesto -->
          <div class="space-y-2">
            <label class="text-sm font-medium text-gray-700">
              Presupuesto estimado
            </label>
            <select
              class="w-full rounded-xl border border-gray-300 px-4 py-3
                     focus:outline-none focus:border-blue-600"
            >
              <option>Menos de $500</option>
              <option>$500 – $1,000</option>
              <option>$1,000 – $3,000</option>
              <option>Más de $3,000</option>
            </select>
          </div>

          <!-- Mensaje -->
          <div class="space-y-2">
            <label class="text-sm font-medium text-gray-700">
              Detalles del proyecto
            </label>
            <textarea
              rows="5"
              placeholder="Cuéntame qué necesitas, plazos, ideas, etc."
              required
              class="w-full rounded-xl border border-gray-300 px-4 py-3
                     focus:outline-none focus:border-blue-600 resize-none"
            ></textarea>
          </div>

          <!-- Botón -->
          <div class="pt-4">
            <button
              type="submit"
              class="inline-flex items-center gap-2 px-8 py-3
                     rounded-full bg-blue-600 text-white font-medium
                     hover:bg-blue-700 transition-all hover:scale-[1.02]"
            >
              Enviar mensaje
              <i class="fas fa-arrow-right text-sm"></i>
            </button>
          </div>
          <!-- Mensaje de confianza -->
          <div class="pt-8 border-t border-gray-200 space-y-6">

            <p class="text-sm text-gray-500 leading-relaxed">
                🔒 Tu información es completamente confidencial.
                No envío spam y respondo normalmente en menos de
            <strong class="text-gray-700">24 horas</strong>.
            </p>

            <!-- Proceso -->
            <div class="grid sm:grid-cols-3 gap-6 text-sm text-gray-600">

              <div class="flex gap-3">
                <span class="text-blue-600 font-semibold">1.</span>
                <p>Reviso tu mensaje y necesidades</p>
              </div>

              <div class="flex gap-3">
                <span class="text-blue-600 font-semibold">2.</span>
                <p>Te contacto con una propuesta clara</p>
              </div>

              <div class="flex gap-3">
                <span class="text-blue-600 font-semibold">3.</span>
                <p>Definimos tiempos y presupuesto</p>
              </div>

            </div>

            <!-- WhatsApp -->
            <div class="flex items-center gap-4 pt-4">
              <span class="text-sm text-gray-500">
                ¿Prefieres contacto directo?
              </span>

              <a
                href="https://wa.me/519XXXXXXXX?text=Hola%20quiero%20información%20sobre%20un%20proyecto"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 text-sm font-medium
                      text-blue-600 hover:text-blue-700 transition"
              >
                <i class="fab fa-whatsapp text-base"></i>
                Escríbeme por WhatsApp
              </a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>
</MainLayout>

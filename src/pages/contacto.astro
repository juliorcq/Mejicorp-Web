---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";

const title = "Contacto | Mejicorp – Desarrollo web y soluciones digitales";
const description =
  "Contáctate con Mejicorp para cotizar desarrollo web, diseño UX/UI, optimización SEO o soluciones digitales a medida.";
---

<MainLayout title={title} description={description}>
  <section class="relative min-h-screen overflow-hidden bg-white py-32">

    <!-- Fondos elegantes -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-[-12rem] right-[-12rem] w-[30rem] h-[30rem] bg-blue-100 rounded-full blur-3xl opacity-60"></div>
      <div class="absolute bottom-[-12rem] left-[-12rem] w-[26rem] h-[26rem] bg-indigo-100 rounded-full blur-3xl opacity-60"></div>
    </div>

    <div class="max-w-5xl mx-auto px-6">

      <!-- Header -->
      <header class="max-w-2xl mb-20">
        <span class="text-sm uppercase tracking-widest text-gray-500">
          Contacto
        </span>

        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-4 leading-tight">
          Hablemos sobre tu
          <span class="text-blue-600 block">proyecto digital</span>
        </h1>

        <p class="text-lg text-gray-600 mt-6">
          Completa el formulario y recibirás una respuesta en menos de 24 horas.
        </p>
      </header>

      <div class="grid lg:grid-cols-3 gap-16">

        <!-- INFO LATERAL -->
        <aside class="space-y-10">

          <!-- Qué incluye -->
          <div class="p-6 rounded-2xl bg-gray-50 border">
            <h3 class="font-semibold text-gray-900 mb-3">
              Tu cotización incluye
            </h3>
        
            <ul class="text-sm text-gray-600 space-y-2">
              <li>✓ Análisis de requerimientos</li>
              <li>✓ Alcance del proyecto</li>
              <li>✓ Tiempo estimado</li>
              <li>✓ Presupuesto detallado</li>
              <li>✓ Tecnologías recomendadas</li>
            </ul>
          </div>
        
          <!-- Tiempos -->
          <div>
            <h4 class="font-medium text-gray-900 mb-3">
              Tiempos promedio
            </h4>
        
            <div class="space-y-3 text-sm text-gray-600">
              <p>Landing page → 3–5 días</p>
              <p>Sitio corporativo → 1–2 semanas</p>
              <p>Sistema web → según alcance</p>
            </div>
          </div>
        
          <!-- Qué enviar -->
          <div>
            <h4 class="font-medium text-gray-900 mb-3">
              Para ayudarte mejor, envía:
            </h4>
        
            <ul class="text-sm text-gray-600 space-y-2">
              <li>• Objetivo del proyecto</li>
              <li>• Referencias o ejemplos</li>
              <li>• Presupuesto aproximado</li>
              <li>• Fecha límite</li>
            </ul>
          </div>
        
          <!-- Confianza -->
          <div class="p-6 rounded-2xl bg-blue-50 border border-blue-100">
            <p class="text-sm text-blue-900">
              Respuesta en menos de 24h.  
              Sin spam. Comunicación directa.
            </p>
          </div>
        
        </aside>
        

        <!-- FORM -->
        <form
            id="contactForm"
            class="lg:col-span-2 bg-white rounded-3xl border border-gray-200
                  p-10 md:p-12 shadow-lg space-y-10"
          >

            <!-- grid -->
            <div class="grid md:grid-cols-2 gap-8">

              <!-- Nombre -->
              <div class="space-y-2">
                <label class="label">Nombre completo</label>
                <input name="name" required class="input" placeholder="Juan Pérez" />
              </div>

              <!-- Email -->
              <div class="space-y-2">
                <label class="label">Correo electrónico</label>
                <input name="email" type="email" required class="input" placeholder="correo@empresa.com" />
              </div>

              <!-- Empresa -->
              <div class="space-y-2">
                <label class="label">Empresa (opcional)</label>
                <input name="company" class="input" placeholder="Mi empresa SAC" />
              </div>

              <!-- Servicio -->
              <div class="space-y-2">
                <label class="label">Servicio</label>
                <select name="service" class="input">
                  <option>Desarrollo web</option>
                  <option>Landing page</option>
                  <option>UX/UI</option>
                  <option>SEO & Performance</option>
                  <option>Sistema a medida</option>
                </select>
              </div>

            </div>

            <!-- Presupuesto ancho completo -->
            <div class="space-y-2">
              <label class="label">Presupuesto estimado</label>
              <select name="budget" class="input">
                <option>Menos de S/.500</option>
                <option>S/.500 – S/.1,000</option>
                <option>S/.1,000 – S/.3,000</option>
                <option>Más de S/.3,000</option>
              </select>
            </div>

            <!-- Mensaje -->
            <div class="space-y-2">
              <label class="label">Detalles del proyecto</label>
              <textarea
                name="message"
                rows="5"
                required
                class="input resize-none"
                placeholder="Cuéntame objetivos, fechas, ideas o referencias..."
              ></textarea>
            </div>

            <!-- CTA -->
            <div class="pt-4 flex flex-col gap-4">

              <button
                id="submitBtn"
                class="btn-primary flex justify-center items-center gap-3"
              >
                Enviar mensaje
                <span id="loader" class="hidden animate-spin">⏳</span>
              </button>

              <p id="statusMsg" class="text-center text-sm hidden"></p>

            </div>

            <!-- Bloque elegante final -->
            <div class="pt-8 border-t border-gray-200 grid sm:grid-cols-3 gap-6 text-xs text-gray-500">

              <div class="flex gap-2">
                <span>🔒</span>
                <p>Datos confidenciales</p>
              </div>

              <div class="flex gap-2">
                <span>⚡</span>
                <p>Respuesta &lt; 24 horas</p>
              </div>

              <div class="flex gap-2">
                <span>💬</span>
                <p>Comunicación directa</p>
              </div>

            </div>

          </form>


        
      </div>
    </div>

  <!-- EmailJS -->
  <script is:inline>
    const form = document.getElementById("contactForm");
    const btn = document.getElementById("submitBtn");
    const loader = document.getElementById("loader");
    const statusMsg = document.getElementById("statusMsg");
  
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
  
      loader.classList.remove("hidden");
      btn.disabled = true;
  
      const data = Object.fromEntries(new FormData(form));
  
      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
  
        if (!res.ok) throw new Error();
  
        form.reset();
  
        statusMsg.textContent = "Mensaje enviado correctamente";
        statusMsg.className = "text-green-600 text-sm text-center";
  
      } catch {
        statusMsg.textContent = "Error enviando mensaje";
        statusMsg.className = "text-red-600 text-sm text-center";
      }
  
      loader.classList.add("hidden");
      btn.disabled = false;
    });
  </script>
  
  
  
</MainLayout>

---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";

const title = "Contacto | Mejicorp – Desarrollo web y soluciones digitales";
const description =
  "Contáctate con Mejicorp para cotizar desarrollo web, diseño UX/UI, optimización SEO o soluciones digitales a medida.";
---

<MainLayout title={title} description={description}>
  <section class="relative min-h-screen overflow-hidden bg-white py-32">

    <!-- Fondos elegantes -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-[-12rem] right-[-12rem] w-[30rem] h-[30rem] bg-blue-100 rounded-full blur-3xl opacity-60"></div>
      <div class="absolute bottom-[-12rem] left-[-12rem] w-[26rem] h-[26rem] bg-indigo-100 rounded-full blur-3xl opacity-60"></div>
    </div>

    <div class="max-w-5xl mx-auto px-6">

      <!-- Header -->
      <header class="max-w-2xl mb-20">
        <span class="text-sm uppercase tracking-widest text-gray-500">
          Contacto
        </span>

        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-4 leading-tight">
          Hablemos sobre tu
          <span class="text-blue-600 block">proyecto digital</span>
        </h1>

        <p class="text-lg text-gray-600 mt-6">
          Completa el formulario y recibirás una respuesta en menos de 24 horas.
        </p>
      </header>

      <div class="grid lg:grid-cols-3 gap-16">

        <!-- INFO LATERAL -->
        <aside class="space-y-10">

          <!-- Qué incluye -->
          <div class="p-6 rounded-2xl bg-gray-50 border">
            <h3 class="font-semibold text-gray-900 mb-3">
              Tu cotización incluye
            </h3>
        
            <ul class="text-sm text-gray-600 space-y-2">
              <li>✓ Análisis de requerimientos</li>
              <li>✓ Alcance del proyecto</li>
              <li>✓ Tiempo estimado</li>
              <li>✓ Presupuesto detallado</li>
              <li>✓ Tecnologías recomendadas</li>
            </ul>
          </div>
        
          <!-- Tiempos -->
          <div>
            <h4 class="font-medium text-gray-900 mb-3">
              Tiempos promedio
            </h4>
        
            <div class="space-y-3 text-sm text-gray-600">
              <p>Landing page → 3–5 días</p>
              <p>Sitio corporativo → 1–2 semanas</p>
              <p>Sistema web → según alcance</p>
            </div>
          </div>
        
          <!-- Qué enviar -->
          <div>
            <h4 class="font-medium text-gray-900 mb-3">
              Para ayudarte mejor, envía:
            </h4>
        
            <ul class="text-sm text-gray-600 space-y-2">
              <li>• Objetivo del proyecto</li>
              <li>• Referencias o ejemplos</li>
              <li>• Presupuesto aproximado</li>
              <li>• Fecha límite</li>
            </ul>
          </div>
        
          <!-- Confianza -->
          <div class="p-6 rounded-2xl bg-blue-50 border border-blue-100">
            <p class="text-sm text-blue-900">
              Respuesta en menos de 24h.  
              Sin spam. Comunicación directa.
            </p>
          </div>
        
        </aside>
        

        <!-- FORM -->
        <form
          id="contactForm"
          class="lg:col-span-2 bg-white rounded-3xl border p-10 shadow-sm space-y-6"
        >

          <input name="name" required placeholder="Nombre completo"
            class="w-full rounded-xl border px-4 py-3 focus:border-blue-600 outline-none" />

          <input name="email" type="email" required placeholder="Correo electrónico"
            class="w-full rounded-xl border px-4 py-3 focus:border-blue-600 outline-none" />

          <input name="company" placeholder="Empresa (opcional)"
            class="w-full rounded-xl border px-4 py-3 focus:border-blue-600 outline-none" />

          <select name="service"
            class="w-full rounded-xl border px-4 py-3 focus:border-blue-600 outline-none">
            <option>Desarrollo web</option>
            <option>Landing page</option>
            <option>UX/UI</option>
            <option>SEO</option>
            <option>Asesoría</option>
          </select>

          <select name="budget"
            class="w-full rounded-xl border px-4 py-3 focus:border-blue-600 outline-none">
            <option>Menos de S/.500</option>
            <option>S/.500 – S/.1,000</option>
            <option>S/.1,000 – S/.3,000</option>
            <option>Más de S/.3,000</option>
          </select>

          <textarea
            name="message"
            rows="5"
            required
            placeholder="Cuéntame los detalles del proyecto..."
            class="w-full rounded-xl border px-4 py-3 focus:border-blue-600 outline-none resize-none"
          ></textarea>

          <!-- BOTÓN -->
          <div class="reveal">
            <button
              id="submitBtn"
              class="w-full bg-blue-600 text-white py-3 rounded-xl font-medium
                    hover:bg-blue-700 transition flex justify-center gap-2"
            >
              Enviar mensaje
              <span id="loader" class="hidden animate-spin"></span>
            </button>
          </div>

          <!-- MENSAJE -->
          <p id="successMsg" class="hidden text-green-600 text-sm text-center">
            Mensaje enviado correctamente. Te responderé pronto.
          </p>

          <!-- confianza -->
          <p class="text-xs text-gray-400 text-center pt-4">
            Información confidencial. Sin spam.
          </p>

        </form>
        
      </div>
    </div>

  <!-- EmailJS -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  
  <script is:inline>
    emailjs.init("tFI5lnOf3xiNHr-Vz");
  
    const form = document.getElementById("contactForm");
    const btn = document.getElementById("submitBtn");
    const loader = document.getElementById("loader");
    const success = document.getElementById("successMsg");
  
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
  
      btn.disabled = true;
      loader.classList.remove("hidden");
  
      try {
        await emailjs.sendForm(
          "service_83d3w6b",
          "template_1317hh2",
          form
        );
  
        form.reset();
        success.classList.remove("hidden");
  
      } catch (err) {
        alert("Error enviando mensaje");
        console.error(err);
      }
  
      loader.classList.add("hidden");
      btn.disabled = false;
    });
  </script>
  
</MainLayout>

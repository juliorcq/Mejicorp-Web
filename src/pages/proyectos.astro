---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";

import p1 from "../assets/proyectos/proyecto_1.png";
import p2 from "../assets/proyectos/proyecto_2.png";
import p3 from "../assets/proyectos/proyecto_3.png";
import p4 from "../assets/proyectos/proyecto_4.png";
import p5 from "../assets/proyectos/proyecto_5.png";
import p6 from "../assets/proyectos/proyecto_6.png";
import p7 from "../assets/proyectos/proyecto_7.png";
import p8 from "../assets/proyectos/proyecto_8.png";
import p9 from "../assets/proyectos/proyecto_9.png";
import p10 from "../assets/proyectos/proyecto_10.png";

const proyectos = [
  {
    img: p1,
    titulo: "Landing corporativa",
    tipo: "web",
    stack: "Astro + Tailwind",
    desc: "Landing rápida enfocada en conversión y posicionamiento SEO."
  },
  {
    img: p2,
    titulo: "Sistema de inventario",
    tipo: "app",
    stack: "Node + MongoDB",
    desc: "Gestión de productos, reportes y control de stock en tiempo real."
  },
  {
    img: p3,
    titulo: "Portal educativo",
    tipo: "web",
    stack: "Laravel",
    desc: "Plataforma con registro de usuarios y contenido dinámico."
  },
  {
    img: p4,
    titulo: "E-commerce",
    tipo: "app",
    stack: "React + API",
    desc: "Tienda online con pagos y administración de pedidos."
  },
  {
    img: p5,
    titulo: "Dashboard analítico",
    tipo: "app",
    stack: "Charts + API",
    desc: "Visualización de datos empresariales en tiempo real."
  },
  {
    img: p6,
    titulo: "Blog optimizado",
    tipo: "web",
    stack: "Astro SSG",
    desc: "Blog ultrarrápido con SEO técnico avanzado."
  },
  {
    img: p7,
    titulo: "Sistema hotelero",
    tipo: "app",
    stack: "Fullstack",
    desc: "Reservas, habitaciones y pagos online."
  },
  {
    img: p8,
    titulo: "Certificados digitales",
    tipo: "app",
    stack: "Laravel + Flask",
    desc: "Generación automática de certificados PDF."
  },
  {
    img: p9,
    titulo: "Portafolio profesional",
    tipo: "web",
    stack: "Astro",
    desc: "Sitio personal moderno enfocado en branding."
  },
  {
    img: p10,
    titulo: "Landing marketing",
    tipo: "web",
    stack: "HTML + SEO",
    desc: "Campañas de alto rendimiento para conversión."
  }
];
---
<MainLayout
  title="Proyectos | Mejicorp"
  description="Portafolio de proyectos digitales desarrollados por Mejicorp."
>

<section class="bg-gradient-to-br from-slate-50 via-white to-indigo-50 py-32">

<div class="max-w-7xl mx-auto px-6 space-y-28">

  <!-- INTRO -->
  <header class="max-w-3xl space-y-6">
    <span class="text-sm uppercase tracking-widest text-gray-500">Portafolio</span>

    <h1 class="text-5xl font-bold text-gray-900 leading-tight">
      Proyectos digitales
      <span class="text-blue-600 block">que generan resultados reales</span>
    </h1>

    <p class="text-lg text-gray-600 leading-relaxed">
      Cada proyecto está construido con enfoque en rendimiento, UX y escalabilidad.
      No solo diseño interfaces bonitas, desarrollo soluciones que funcionan.
    </p>
  </header>

  <!-- MÉTRICAS -->
  <div class="grid sm:grid-cols-3 gap-10 text-center">
    <div>
      <p class="text-4xl font-bold text-blue-600">+30</p>
      <p class="text-gray-600 text-sm">Proyectos realizados</p>
    </div>
    <div>
      <p class="text-4xl font-bold text-blue-600">95%</p>
      <p class="text-gray-600 text-sm">Clientes satisfechos</p>
    </div>
    <div>
      <p class="text-4xl font-bold text-blue-600">⚡</p>
      <p class="text-gray-600 text-sm">Rendimiento optimizado</p>
    </div>
  </div>

  <!-- FILTROS -->
  <div class="flex gap-4 justify-center">
    <button class="filterBtn px-5 py-2 border rounded-full" data-filter="all">Todos</button>
    <button class="filterBtn px-5 py-2 border rounded-full" data-filter="web">Web</button>
    <button class="filterBtn px-5 py-2 border rounded-full" data-filter="app">Apps</button>
  </div>

  <!-- GRID PROYECTOS -->
  <div id="grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">

    {proyectos.map((p) => (
      <article
          class="project group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-500 overflow-hidden"
          data-type={p.tipo}
        >

        <Image
          src={p.img}
          alt={p.titulo}
          width={600}
          height={400}
          format="webp"
          class="w-full h-48 object-cover"
        />

        <div class="p-6 space-y-3">
          <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition">
            {p.titulo}
          </h3>

          <p class="text-sm text-gray-600">{p.desc}</p>

          <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">
            {p.stack}
          </span>
        </div>
      </article>
    ))}

  </div>

  <!-- CTA FINAL -->
  <div class="text-center space-y-6">
    <h3 class="text-2xl font-semibold text-gray-900">
      ¿Quieres tu próximo proyecto aquí?
    </h3>

    <a
      href="/contacto"
      class="inline-flex px-8 py-3 rounded-xl
             bg-gradient-to-r from-blue-600 to-indigo-600
             text-white font-medium hover:scale-105 transition"
    >
      Solicitar cotización
    </a>
  </div>

</div>
</section>

<!-- JS ligero para filtros -->
<script is:inline>
  const buttons = document.querySelectorAll(".filterBtn");
  const projects = [...document.querySelectorAll(".project")];

  const duration = 400;
  const stagger = 80;

  // ---- FLIP animation ----
  function animateLayout() {
    const firstRects = new Map();

    projects.forEach(el => {
      firstRects.set(el, el.getBoundingClientRect());
    });

    requestAnimationFrame(() => {
      projects.forEach(el => {
        const last = el.getBoundingClientRect();
        const first = firstRects.get(el);

        const dx = first.left - last.left;
        const dy = first.top - last.top;

        if (dx || dy) {
          el.animate(
            [
              { transform: `translate(${dx}px, ${dy}px)` },
              { transform: "translate(0,0)" }
            ],
            {
              duration,
              easing: "ease-out"
            }
          );
        }
      });
    });
  }

  function show(el, delay) {
    el.style.display = "block";

    setTimeout(() => {
      el.classList.remove("opacity-0", "scale-95", "translate-y-4");
      el.classList.add("opacity-100", "scale-100", "translate-y-0");
    }, delay);
  }

  function hide(el) {
    el.classList.remove("opacity-100", "scale-100", "translate-y-0");
    el.classList.add("opacity-0", "scale-95", "translate-y-4");

    setTimeout(() => {
      el.style.display = "none";
    }, duration);
  }

  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      // botón activo
      buttons.forEach(b => b.classList.remove("bg-blue-600", "text-white"));
      btn.classList.add("bg-blue-600", "text-white");

      animateLayout();

      let i = 0;

      projects.forEach(card => {
        const type = card.dataset.type;

        if (filter === "all" || type === filter) {
          show(card, i * stagger);
        } else {
          hide(card);
        }
      });
    });
  });
</script>



</MainLayout>

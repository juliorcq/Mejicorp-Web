---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Servicios | Mejicorp">
  <main class="max-w-7xl mx-auto px-6 py-32 space-y-32">

    <!-- HEADER -->
    <section class="space-y-6 max-w-3xl">
      <h1 class="text-4xl font-bold">Servicios</h1>
      <p class="text-lg text-gray-600">
        Desarrollo soluciones digitales pensadas para crecer,
        optimizadas desde el diseño hasta el rendimiento final.
      </p>
    </section>

    <!-- SERVICIO 1 -->
    <section class="grid lg:grid-cols-2 gap-20 items-center">
      <img
        src="/images/Servicios_desarrollo_web.jpg"
        alt="Desarrollo web"
        class="w-full max-w-md mx-auto"
      />

      <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Desarrollo Web</h2>

        <p class="text-gray-600">
          Creación de sitios web rápidos, escalables y mantenibles,
          desarrollados con tecnologías modernas y buenas prácticas.
        </p>

        <ul class="space-y-3 text-gray-700">
          <li>✔ Sitios corporativos</li>
          <li>✔ Landing pages</li>
          <li>✔ Paneles administrativos</li>
          <li>✔ Integraciones externas</li>
        </ul>

        <div class="grid sm:grid-cols-3 gap-6 text-sm">
          <div class="bg-gray-50 p-4 rounded-xl">
            ⏱ <strong>Tiempo:</strong><br />7 – 15 días
          </div>
          <div class="bg-gray-50 p-4 rounded-xl">
            💻 <strong>Tecnologías:</strong><br />Astro, Tailwind, JS
          </div>
          <div class="bg-gray-50 p-4 rounded-xl">
            💰 <strong>Desde:</strong><br />S/ 1,200
          </div>
        </div>

        <a
          href="/contacto"
          class="inline-flex px-7 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition reveal"
        >
          Cotizar desarrollo
        </a>
      </div>
    </section>

    <!-- SERVICIO 2 -->
    <section class="grid lg:grid-cols-2 gap-20 items-center">
      <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Diseño UX / UI</h2>

        <p class="text-gray-600">
          Diseño centrado en el usuario, priorizando claridad,
          accesibilidad y conversión.
        </p>

        <ul class="space-y-3 text-gray-700">
          <li>✔ Wireframes</li>
          <li>✔ Prototipos</li>
          <li>✔ Diseño responsive</li>
          <li>✔ Diseño editorial</li>
        </ul>

        <div class="grid sm:grid-cols-3 gap-6 text-sm">
          <div class="bg-gray-50 p-4 rounded-xl">
            ⏱ <strong>Tiempo:</strong><br />3 – 6 días
          </div>
          <div class="bg-gray-50 p-4 rounded-xl">
            🎨 <strong>Herramientas:</strong><br />Figma
          </div>
          <div class="bg-gray-50 p-4 rounded-xl">
            💰 <strong>Desde:</strong><br />S/ 400
          </div>
        </div>

        <a
          href="/contacto"
          class="inline-flex px-7 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition reveal"
        >
          Cotizar diseño
        </a>
      </div>

      <img
        src="/images/Servicios_diseño.jpg"
        alt="Diseño UX UI"
        class="w-full max-w-md mx-auto"
      />
    </section>

    <!-- SERVICIO 3 -->
    <section class="grid lg:grid-cols-2 gap-20 items-center">
      <img
        src="/images/Servicios_seo.jpg"
        alt="SEO y performance"
        class="w-full max-w-md mx-auto"
      />

      <div class="space-y-6">
        <h2 class="text-2xl font-semibold">SEO & Performance</h2>

        <p class="text-gray-600">
          Optimización técnica para mejorar visibilidad,
          velocidad y experiencia de usuario.
        </p>

        <ul class="space-y-3 text-gray-700">
          <li>✔ SEO técnico</li>
          <li>✔ Optimización de imágenes</li>
          <li>✔ Core Web Vitals</li>
          <li>✔ Accesibilidad</li>
        </ul>

        <div class="grid sm:grid-cols-3 gap-6 text-sm">
          <div class="bg-gray-50 p-4 rounded-xl">
            ⏱ <strong>Tiempo:</strong><br />2 – 4 días
          </div>
          <div class="bg-gray-50 p-4 rounded-xl">
            🚀 <strong>Objetivo:</strong><br />Carga rápida
          </div>
          <div class="bg-gray-50 p-4 rounded-xl">
            💰 <strong>Desde:</strong><br />S/ 300
          </div>
        </div>

        <a
          href="/contacto"
          class="inline-flex px-7 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition reveal"
        >
          Mejorar mi sitio
        </a>
      </div>
    </section>

  </main>
</MainLayout>

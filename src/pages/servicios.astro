---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Servicios | Mejicorp">
  <main class="max-w-7xl mx-auto px-6 py-32 space-y-24">

    <section>
      <h1 class="text-4xl font-bold mb-6">Servicios</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        Desarrollo soluciones digitales enfocadas en rendimiento,
        experiencia de usuario y escalabilidad.
      </p>
    </section>

    <section class="grid md:grid-cols-3 gap-10">
      <div class="p-8 rounded-2xl border">
        <h3 class="font-semibold mb-3">Desarrollo Web</h3>
        <p class="text-gray-600">Sitios rápidos, modernos y optimizados.</p>
      </div>

      <div class="p-8 rounded-2xl border">
        <h3 class="font-semibold mb-3">UX / UI</h3>
        <p class="text-gray-600">Diseño claro enfocado en conversión.</p>
      </div>

      <div class="p-8 rounded-2xl border">
        <h3 class="font-semibold mb-3">SEO & Performance</h3>
        <p class="text-gray-600">Mejor visibilidad y velocidad.</p>
      </div>
    </section>

    <a
      href="https://wa.me/519XXXXXXXX?text=Hola%2C%20quiero%20cotizar%20un%20servicio"
      target="_blank"
      class="inline-flex px-7 py-3 bg-blue-600 text-white rounded-xl"
    >
      Cotizar servicio
    </a>

  </main>
</MainLayout>
